{
  "manifest_version": 3,
  "name": "X Silly Feed",
  "version": "1.0",
  "description": "Transforms X.com UI into a silly, sketch-inspired newspaper style.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://*.x.com/*",
    "https://*.twitter.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.x.com/*", "https://*.twitter.com/*"],
      "js": ["content/content.js"],
      "css": ["content/styles.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
